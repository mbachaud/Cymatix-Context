    {
      "datasource": "Prometheus",
      "description": "helix_dense_cosine — raw cosine of every dense-tier hit at its computation site. arm=hot is the BGE-M3 dense-recall merge in query_genes (pre-weight, pre-floor); arm=cold is the cold-tier ΣĒMA scan. Calibration data for dense_additive_weight / dense_additive_min_cosine (#203, #209).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
