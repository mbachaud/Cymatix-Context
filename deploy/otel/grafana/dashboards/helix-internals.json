      "title": "Dense cosine distribution (p50 / p95 by arm)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum by (le, arm) (rate(helix_dense_cosine_bucket[5m])))",
          "legendFormat": "{{arm}} p50",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le, arm) (rate(helix_dense_cosine_bucket[5m])))",
          "legendFormat": "{{arm}} p95",
          "refId": "B"
        }
      ]
    },
