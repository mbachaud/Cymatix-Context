    {
      "datasource": "Prometheus",
      "description": "helix_shard_discrimination — routed / known healthy shards per query, mean over 5m. 1.0 = the router consults every shard (zero discrimination, #165 degeneracy); lower is a more selective route. Acceptance metric for the AND-mode router.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.95
              }
            ]
          },
          "unit": "percentunit"
